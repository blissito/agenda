{
  "name": "agenda",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "deploy": "npm run build && fly deploy --remote-only",
    "build": "cross-env NODE_ENV=production react-router build",
    "dev": "react-router dev",
    "prisma": "npx -y prisma generate",
    "start": "cross-env NODE_ENV=production react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@aws-sdk/client-s3": "^3.712.0",
    "@aws-sdk/client-sesv2": "^3.927.0",
    "@aws-sdk/s3-request-presigner": "^3.712.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@easybits.cloud/html-tailwind-generator": "^0.2.127",
    "@faker-js/faker": "^10.1.0",
    "@formmy.app/chat": "^0.0.23",
    "@headlessui/react": "^2.1.2",
    "@hectorbliss/denik-calendar": "file:packages/calendar",
    "@hokify/agenda": "^6.3.0",
    "@motionone/utils": "^10.18.0",
    "@preact/signals-react": "^3.4.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@tailwindcss/forms": "^0.5.9",
    "ai": "^6.0.116",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "grapesjs": "^0.22.14",
    "isbot": "^5.1.32",
    "js-confetti": "^0.13.1",
    "jsonwebtoken": "^9.0.3",
    "lottie-react": "^2.4.1",
    "mercadopago": "^2.12.0",
    "motion": "^12.23.24",
    "nanoid": "^5.0.9",
    "node-schedule": "^2.1.1",
    "nodemailer": "^7.0.12",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-day-picker": "^9.0.4",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.52.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.2.1",
    "react-router": "^7.12.0",
    "react-scroll-parallax": "^3.5.0",
    "recharts": "^3.8.0",
    "slugify": "^1.6.6",
    "stripe": "^19.3.0",
    "tailwind-merge": "^3.4.0",
    "tiny-invariant": "^1.3.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@react-router/dev": "^7.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.10.0",
    "@types/nodemailer": "^7.0.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.20",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.49",
    "prisma": "^6.0.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^7.2.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
