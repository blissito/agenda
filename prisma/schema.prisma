model Customer {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  comments            String
  createdAt           DateTime             @db.Date
  displayName         String
  email               String
  orgId               String               @db.ObjectId
  tel                 String
  updatedAt           DateTime             @db.Date
  userId              String?              @db.ObjectId
  blocked             Boolean?             @default(false)
  // Loyalty program fields (optional — org may not activate loyalty)
  loyaltyPoints       Int?                 @default(0)
  loyaltyTotalEarned  Int?                 @default(0)
  loyaltyTier         String?              @default("bronze") // deprecated — kept for backward compat
  loyaltyLevelId      String?              @db.ObjectId        // references LoyaltyLevel
  // Expediente: ficha estructurada (intake) — campos según giro de la org. Las
  // entradas del timeline viven en el modelo CustomerRecordEntry (scalar-only).
  intake              Json?
  // Sede preferida del cliente (opcional). El cliente sigue siendo org-wide;
  // esto solo pre-selecciona la sucursal en el booking.
  preferredBranchId   String?              @db.ObjectId
  org                 Org                  @relation(fields: [orgId], references: [id])
  user                User?                @relation(fields: [userId], references: [id])
  events              Event[]
  surveyResponses     SurveyResponse[]
  loyaltyTransactions LoyaltyTransaction[]
  loyaltyRedemptions  LoyaltyRedemption[]

  @@unique([email, orgId])
  @@index([orgId])
}

model Event {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  allDay           Boolean
  archived         Boolean
  createdAt        DateTime  @db.Date
  customerId       String?   @db.ObjectId
  duration         BigInt
  employeeId       String?   @db.ObjectId
  end              DateTime? @db.Date
  notes            String?
  orgId            String    @db.ObjectId
  paid             Boolean
  payment_method   String?
  serviceId        String?   @db.ObjectId
  start            DateTime  @db.Date
  status           String
  title            String
  type             String
  updatedAt        DateTime  @db.Date
  userId           String    @db.ObjectId
  mp_preference_id         String?
  mp_payment_id            String?
  stripe_session_id        String?
  stripe_payment_intent_id String?
  meetingLink              String?
  calendarEventId          String?
  calendarHtmlLink         String?
  zoomMeetingId            String?
  videoProvider            String?              // "meet" | "zoom" | "none" (snapshot al crear)
  attended                 Boolean?             // null = not marked, true = attended, false = no-show
  reminderSentAt           DateTime? @db.Date  // null = reminder not sent yet
  confirmationSentAt       DateTime? @db.Date  // null = confirmation request not sent yet
  // Set when the customer clicks the confirmation link from createPublicBooking.
  // null = pending confirmation (no Meet/Zoom + no owner notification yet).
  confirmedAt              DateTime? @db.Date
  surveySentAt             DateTime? @db.Date  // null = survey not sent yet
  refundedAt               DateTime? @db.Date  // null = no refund. Set al cancelar una cita pagada cuando el dueño marca reembolso
  rescheduleCount          Int       @default(0)   // veces que el cliente ha reagendado este evento
  // Snapshot de la sede donde ocurre la cita (como videoProvider). Nullable
  // durante la migración; se vuelve required tras el backfill (Fase 2).
  branchId         String?   @db.ObjectId
  // "Carril" del slot para capacidad simultánea (Service.seats). Cada reserva
  // del mismo (serviceId, branchId, start) toma un índice 0..capacidad-1. Con
  // capacidad 1 siempre es 0 ⇒ equivale al unique_slot histórico.
  slotIndex        Int       @default(0)
  customer                 Customer?       @relation(fields: [customerId], references: [id])
  org              Org       @relation(fields: [orgId], references: [id])
  service          Service?  @relation(fields: [serviceId], references: [id])
  branch           Branch?   @relation(fields: [branchId], references: [id])
  surveyResponse   SurveyResponse?

  // Previene doble reserva del mismo carril. Branch-aware (multi-sede) y
  // capacity-aware (slotIndex): permite hasta `seats` reservas por slot.
  @@unique([serviceId, branchId, start, slotIndex], name: "unique_slot")

  @@index([orgId])
  @@index([customerId])
  @@index([status])
  @@index([branchId])
}

model Job {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model Org {
