  businessType       String?
  config             OrgConfig?
  customDomain       String?
  customDomainStatus String?
  customDomainDns    Json?
  description        String?
  email              String?
  isActive           Boolean
  integrations       OrgIntegrations?
  logo               String?
  loyaltyEnabled     Boolean           @default(false)
  /// Could not determine type: the field only had null or empty values in the sample set.
  location           Json?
  name               String
  numberOfEmployees  String?
  ownerId            String            @db.ObjectId
  plugins            Json?
  shopKeeper         String?
  slug               String            @unique
  apiKey             String?           @unique
  // Public-scope API key for the landing chatbot / Formmy public agents.
  // Prefix `dnk_pub_` — exposes only read tools + create_booking (free).
  publicApiKey       String?           @unique
  social             OrgSocial?
  tel                String?
  timezone           String?           // e.g. "America/Mexico_City"
  websiteConfig      OrgWebsiteConfig?
  /// Could not determine type: the field only had null or empty values in the sample set.
  week               Json?
  weekDays           OrgWeekDays?
  landingSections    Json?
  landingTheme          String?
  landingCustomColors   Json?
  landingPublished      Boolean           @default(false)
  landingChatbotEnabled Boolean           @default(true)
  landingGenCount       Int               @default(0)
  landingRefineCount    Int               @default(0)
  landingUsageMonth     String?
  // AI cost tracking (USD). Lifetime totals — never reset.
  landingTotalCostUsd   Float             @default(0)
  landingTotalGens      Int               @default(0)
  landingTotalRefines   Int               @default(0)
  brandkit              OrgBrandkit?
  chatbotAgentId        String?
  chatbotConfig         Json?
  googleCalendarToken   Json?
  zoomToken             Json?
  // Expediente: plantillas de campos personalizables por org. Forma:
  // { ficha: TemplateField[], atencion: TemplateField[] }. Si es null se
  // siembra desde los defaults del giro (Org.businessType). Ver customer-record.server.ts
  recordTemplates       Json?
  // Sede creada en el backfill (sucursal "Principal"). Default para la sede activa.
  defaultBranchId    String?           @db.ObjectId
  customers          Customer[]
  events             Event[]
  services           Service[]
  branches           Branch[]
}

/// Link entre una Org y un grupo de WhatsApp provisionado vía Nanoclaw.
/// El flow completo está en docs/nanoclaw/droplet/README.md y en el plan.
model WhatsAppLink {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  orgId       String    @db.ObjectId
  userId      String    @db.ObjectId
  token       String    @unique                  // nanoid(32), usado en el callback
  status      String                              // pending | provisioned | active | revoked
  groupJid    String?   @unique                   // llega en el callback de Nanoclaw
  inviteUrl   String?
  createdAt   DateTime  @default(now()) @db.Date
  activatedAt DateTime? @db.Date
  revokedAt   DateTime? @db.Date

  @@index([orgId])
}

/// Expediente del cliente — timeline clínico/estético. Cada entrada es un
/// registro de lo realizado (tratamiento, nota, evolución, resultado).
/// Scalar-only (sin @relation) al estilo WhatsAppLink; se consulta por
/// customerId/orgId. Acceso: owner + colaboradores. Gating: plan PRO del owner.
model CustomerRecordEntry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orgId       String   @db.ObjectId
  customerId  String   @db.ObjectId
  eventId     String?  @db.ObjectId   // liga opcional a la cita donde se realizó
  authorId    String   @db.ObjectId   // user (owner/colaborador) que la escribió
  authorName  String?                 // snapshot del nombre del autor al crear
  type        String                  // "nota" | "tratamiento" | "evolucion" | "resultado"
  title       String?
  body        String                  // descripción / observaciones
  attachments String[]                // keys de Tigris (fotos antes/después) — Fase 2
  metadata    Json?                   // estructurado por giro/tipo: productos, área, mediciones
  performedAt DateTime @db.Date        // cuándo se realizó (puede diferir de createdAt)
  createdAt   DateTime @default(now()) @db.Date
  updatedAt   DateTime @updatedAt @db.Date

  @@index([orgId])
  @@index([customerId])
  @@index([eventId])
}

model Service {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  address       String?
  lat           Float?
  lng           Float?
  allowMultiple Boolean
  archived      Boolean
  config        ServiceConfig?
  currency      String
  description   String?
  duration      BigInt
  breakTime     BigInt?
  employeeName  String?
  isActive      Boolean
  limit         ServiceLimit?
  name          String
  orgId         String           @db.ObjectId
  paid          Boolean
  payment       Boolean
  gallery       String[]
  place         String
  points        BigInt
  price         BigInt
  seats         BigInt
  slug          String           @unique
  videoProvider String           @default("auto") // "auto" | "meet" | "zoom" | "none"
  weekDays      ServiceWeekDays?
  org           Org              @relation(fields: [orgId], references: [id])
  events        Event[]
  actions       ServiceAction[]
  // Sedes donde se ofrece el servicio (M2M). Campos del Service son los defaults
  // heredables; cada ServiceBranch puede sobrescribir price/weekDays/isActive.
  serviceBranches ServiceBranch[]

  @@index([orgId])
}

model ServiceAction {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  serviceId String  @db.ObjectId
  type      String
  config    Json
  enabled   Boolean @default(true)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

// Sucursal (sede física) de una Org. Dueño natural de dirección + horarios +
// timezone (lo que hoy vive plano en Org para orgs single-location).
model Branch {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  orgId     String          @db.ObjectId
  name      String
  slug      String // único dentro de la org (@@unique([orgId, slug]))
  isActive  Boolean         @default(true)
  isDefault Boolean         @default(false) // sede "Principal" creada en el backfill
  address   String?
  lat       Float?
  lng       Float?
  timezone  String?
  weekDays  BranchWeekDays?
  tel       String?
  email     String?
  createdAt DateTime        @default(now()) @db.Date

  org             Org             @relation(fields: [orgId], references: [id])
  serviceBranches ServiceBranch[]
  events          Event[]

  @@unique([orgId, slug])
  @@index([orgId])
}

// Tabla pivote Service<->Branch (M2M). Un servicio puede ofrecerse en varias
// sedes o en una sola. Los overrides (price/weekDays/isActive) son opcionales:
// null = hereda del Service.
model ServiceBranch {
  id        String                 @id @default(auto()) @map("_id") @db.ObjectId
  serviceId String                 @db.ObjectId
  branchId  String                 @db.ObjectId
  isActive  Boolean                @default(true) // pausar el servicio en una sede
  price     BigInt? // override de precio en esta sede
  weekDays  ServiceBranchWeekDays? // override de horario en esta sede
  service   Service                @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  branch    Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([serviceId, branchId])
  @@index([serviceId])
  @@index([branchId])
}

model SurveyResponse {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId    String   @unique @db.ObjectId
  customerId String   @db.ObjectId
  orgId      String   @db.ObjectId
  serviceId  String   @db.ObjectId

  // Response data (v1: simple satisfaction survey)
  rating     Int      // 1-5 scale
  comment    String?  // Optional feedback text
  hidden     Boolean  @default(false)

  createdAt  DateTime @db.Date

  // Future extensibility: answers Json? for custom questions

  // Relations
  event      Event    @relation(fields: [eventId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])

  // Note: eventId is unique so only one response per event

  @@index([orgId])
  @@index([serviceId])
}

model User {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  accessToken   String?
  displayName   String?
  email         String           @unique
  emailVerified Boolean
  orgId         String?          @db.ObjectId
  orgIds        String[]
  // Sedes donde atiende el colaborador (vacío = todas las sedes de la org).
  branchIds     String[]         @db.ObjectId
  /// Could not determine type: the field only had null or empty values in the sample set.
  phoneNumber   Json?
  photoURL      String?
  providerId    String?
  role          String           @default("user")
  plan                      String?   // "TRIAL" | "PRO" | "ENTERPRISE" | "EXPIRED" — null for customers/collaborators
  trialStartsAt             DateTime? @db.Date
  trialEndsAt               DateTime? @db.Date
  trialWarningEmailSentAt   DateTime? @db.Date
  trialExpiredEmailSentAt   DateTime? @db.Date
  onboardingCelebratedAt    DateTime? @db.Date
  // Pasos de onboarding persistidos en DB (no localStorage) para que el banner
  // de la sidebar se oculte solo y el progreso sobreviva entre dispositivos.
  onboardingVisitedSiteAt   DateTime? @db.Date
  onboardingSharedLinkAt    DateTime? @db.Date
  // Platform subscription billing (Stripe Billing — distinct from `stripe` field which is Connect legacy)
  customerId           String?
  subscriptionIds      String[]
  subscriptionStatus   String?   // "active" | "past_due" | "canceled" | "incomplete" | etc.
  currentPeriodEnd     DateTime? @db.Date
  stripe        UserStripe?
  mercadopago   UserMercadoPago?
  uid           String?
  customers     Customer[]
}

// ==================== LOYALTY SYSTEM ====================

// Custom loyalty levels defined per-org
model LoyaltyLevel {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  orgId           String   @db.ObjectId
  name            String
  image           String?
  minPoints       Int
  discountPercent Float
  serviceIds      String[] @db.ObjectId
  order           Int      @default(0)
  createdAt       DateTime @default(now()) @db.Date
  updatedAt       DateTime @updatedAt @db.Date

  @@index([orgId])
  @@index([orgId, minPoints])
}

// Audit trail for all point changes
model LoyaltyTransaction {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  orgId      String   @db.ObjectId
  eventId    String?  @db.ObjectId // Link to booking that generated points

  type       String   // "earn" | "redeem" | "adjust" | "expire"
  points     Int      // + for earn, - for redeem
  balance    Int      // Balance after transaction
  reason     String   // "booking_completed" | "first_visit_bonus" | "tier_bonus" | "manual" | "redemption"
  metadata   Json?    // Extra data for extensibility (e.g., tier multiplier applied)

  createdAt  DateTime @default(now()) @db.Date

  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, orgId])
  @@index([orgId, createdAt])
}

// Catalog of rewards that customers can redeem
model LoyaltyReward {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  orgId              String              @db.ObjectId
  name               String              // "10% descuento", "Servicio gratis"
  description        String?
  type               String              // "discount_percent" | "discount_fixed" | "free_service"
  value              Int                 // 10 = 10%, or fixed amount in cents
  pointsCost         Int                 // Points required to redeem
  isActive           Boolean             @default(true)
  minTier            String?             // Minimum tier required (null = all tiers)
  maxRedemptions     Int?                // null = unlimited
  currentRedemptions Int                 @default(0)
  createdAt          DateTime            @default(now()) @db.Date
  updatedAt          DateTime            @updatedAt @db.Date

  redemptions        LoyaltyRedemption[]

  @@index([orgId, isActive])
}

// Individual redemption records
model LoyaltyRedemption {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  customerId    String    @db.ObjectId
  orgId         String    @db.ObjectId
  rewardId      String    @db.ObjectId
  transactionId String    @db.ObjectId // Link to the LoyaltyTransaction that deducted points

  code          String    @unique // Unique code to use the reward
  status        String    // "pending" | "used" | "expired"
  usedAt        DateTime? @db.Date
  expiresAt     DateTime  @db.Date

  createdAt     DateTime  @default(now()) @db.Date

  customer      Customer      @relation(fields: [customerId], references: [id])
  reward        LoyaltyReward @relation(fields: [rewardId], references: [id])

  @@index([customerId, status])
  @@index([orgId, createdAt])
}

model AssistantMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orgId     String   @db.ObjectId
  role      String   // "user" | "assistant"
  content   String
  status    String?  // "pending" | "delivered"
  createdAt DateTime @default(now()) @db.Date

  @@index([orgId, createdAt])
}
